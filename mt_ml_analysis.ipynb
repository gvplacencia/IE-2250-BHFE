       "task_data = df.select(["Task t1", "Task t2"])\n",
       "task_data = task_data.rename({"Task t1":"Task 1", "Task t2":"Task 2"})\n",

    "print(task_data.head())\n",
    "print(task_data.describe())\n",


    "# -------------------------------------------------------\n",
    "# Build the combined dataframe for ML\n",
    "# -------------------------------------------------------\n",
    "times = np.concatenate([task_a_times, task_b_times])\n",
    "labels = np.array([0] * n_subjects + [1] * n_subjects)  # 0=Task A, 1=Task B\n",
    "subject_ids = list(range(1, n_subjects+1)) * 2\n",
